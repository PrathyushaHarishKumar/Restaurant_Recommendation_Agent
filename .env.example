# Restaurant AI Agent — Environment Variables
# Copy this file to .env and adjust values as needed
# None of these are required to run locally — defaults work out of the box

FLASK_PORT=5000
FLASK_DEBUG=true
CSV_PATH=data/restaurants.csv
TOP_N_RESULTS=5

# Optional: Yelp API (not wired in yet — ask an AI to add it)
# YELP_API_KEY=your_yelp_api_key_here

# Optional: OpenAI (not wired in yet — ask an AI to replace NLPQueryParser)
# OPENAI_API_KEY=your_openai_api_key_here
